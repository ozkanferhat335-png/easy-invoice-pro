<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  
  <appSettings>
    <!-- DATABASE SETTINGS -->
    <add key="DatabasePath" value="EasyInvoicePro.db" />
    <add key="DatabasePassword" value="EasyInvoicePro2024!" />
    <add key="DatabaseEncryption" value="true" />
    
    <!-- APPLICATION SETTINGS -->
    <add key="AppTitle" value="EasyInvoice Pro" />
    <add key="AppVersion" value="1.0.0" />
    <add key="Language" value="tr" />
    <add key="Theme" value="Light" />
    
    <!-- E-FATURA SETTINGS -->
    <add key="eFaturaTestUrl" value="https://efatura-test.uyumsoft.com.tr/Services/Integration/UEBIntegratorV3?wsdl" />
    <add key="eFaturaProdUrl" value="https://efatura.gov.tr/Services/Integration/UEBIntegratorV3?wsdl" />
    <add key="eFaturaEnvironment" value="Test" />
    <add key="eFaturaTimeout" value="30000" />
    
    <!-- LICENSE SETTINGS -->
    <add key="LicenseServer" value="https://api.easyinvoicepro.com/license" />
    <add key="DemoExpireDays" value="30" />
    <add key="MaxInvoicesDemo" value="50" />
    <add key="MaxInvoicesPro" value="500" />
    
    <!-- BACKUP SETTINGS -->
    <add key="AutoBackupEnabled" value="true" />
    <add key="AutoBackupInterval" value="24" />
    <add key="BackupPath" value="Backups" />
    
    <!-- REPORT SETTINGS -->
    <add key="ReportPath" value="Reports" />
    <add key="PDFPageSize" value="A4" />
    <add key="ExcelDateFormat" value="dd.MM.yyyy" />
  </appSettings>
  
  <connectionStrings>
    <add name="DefaultConnection" connectionString="Data Source=EasyInvoicePro.db;Version=3;" />
  </connectionStrings>
</configuration>